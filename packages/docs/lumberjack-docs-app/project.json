{
  "name": "docs-lumberjack-docs-app",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/docs/lumberjack-docs-app/src",
  "prefix": "ngworker",
  "targets": {
    "build": {
      "outputs": ["{workspaceRoot}/dist/packages/docs/lumberjack-docs-app"],
      "command": "astro build",
      "cache": true,
      "options": {
        "cwd": "packages/docs/lumberjack-docs-app"
      }
    },
    "typecheck": {
      "command": "astro check",
      "cache": true,
      "options": {
        "cwd": "packages/docs/lumberjack-docs-app"
      }
    },
    "start": {
      "command": "astro dev",
      "continuous": true,
      "options": {
        "cwd": "packages/docs/lumberjack-docs-app"
      }
    },
    "serve": {
      "command": "astro preview",
      "continuous": true,
      "options": {
        "cwd": "packages/docs/lumberjack-docs-app"
      }
    }
  },
  "tags": ["scope:public", "type:app"]
}
